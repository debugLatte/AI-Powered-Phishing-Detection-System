{
  "manifest_version": 3,
  "name": "PhishGuard — AI Phishing Detector",
  "version": "1.0.0",
  "description": "AI-powered real-time phishing detection for URLs and emails",

  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "webNavigation",
    "notifications"
  ],

  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "PhishGuard"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["warning.html"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
